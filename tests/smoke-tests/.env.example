# --- generateEvents.mjs ---
# PUBLIC key of the Fingerprint subscription used to generate real events via a
# headless browser identification. Only the public key is needed here.
# "eu" or "ap", "us" is the default.
PUBLIC_KEY=<PUBLIC_KEY>
REGION=<REGION>

# Optional: a public key with Sealed Results enabled, so readOnly.sealedResult is
# populated (unsealResult.mjs is exercised). Pair it with ENCRYPTION_KEY in the
# runExamples section below — set both or neither (a partial config fails fast).
SEALED_PUBLIC_KEY=<SEALED_PUBLIC_KEY>

# Optional: number of destructive update/delete events to generate (must match
# the number of legs in the smoke_tests CI matrix). Defaults to 7.
MATRIX_SIZE=7

# Optional: where the generated JSON is written/read. Defaults to
# ./generated-events.json. Shared with runExamples.mjs below.
GENERATED_EVENTS_FILE=./generated-events.json

# --- runExamples.mjs ---
# SECRET key + region + sealed decryption key used by the example scripts against
# the generated events. These are kept out of generated-events.json and supplied
# here (in CI, from secrets). REGION/ENCRYPTION_KEY are shared with generation above.
PRIVATE_KEY=<PRIVATE_KEY>

# Sealed results decryption key (base64), paired with SEALED_PUBLIC_KEY above.
# Only used here to unseal — never exposed to the generate step.
ENCRYPTION_KEY=<ENCRYPTION_KEY>

# Which leg of the Node version matrix this run is (0-based); picks the
# destructiveUpdate/destructiveDelete entry to use. Defaults to 0.
LEG_INDEX=0

# Optional: the webhook self-test ALWAYS runs (it signs + verifies with its own
# secret). If this is unset, a random test-only secret is generated for it.
WEBHOOK_SIGNATURE_SECRET=<WEBHOOK_SIGNATURE_SECRET>
